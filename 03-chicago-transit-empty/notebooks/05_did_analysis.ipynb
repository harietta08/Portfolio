   "source": [
    "FARE_REVENUE     = 1.75   # dollars per boarding\n",
    "EXTRA_BUS_COST   = 3500   # estimated $/week for 1 additional bus + operator\n",
    "\n",
    "daily_revenue    = did_estimate * FARE_REVENUE\n",
    "weekly_revenue   = daily_revenue * 7\n",
    "weekly_net       = weekly_revenue - EXTRA_BUS_COST\n",
    "weeks_to_roi     = EXTRA_BUS_COST / (weekly_revenue) if weekly_revenue > 0 else float('inf')\n",
    "annual_net       = weekly_net * 52\n",
    "\n",
    "print('=' * 55)\n",
    "print('  ROI CALCULATION')\n",
