    "print(f'  Weekly additional revenue  : ${weekly_revenue:,.0f}')\n",
    "print(f'  Estimated incremental cost : ${EXTRA_BUS_COST:,}/week')\n",
    "print(f'  Weekly net gain            : ${weekly_net:+,.0f}')\n",
    "print(f'  Weeks to break even        : {weeks_to_roi:.1f} weeks')\n",
    "print(f'  Annual net revenue impact  : ${annual_net:+,.0f}/year (after break-even)')\n",
    "print()\n",
    "print(f'  CONCLUSION: ROI positive after {weeks_to_roi:.0f} weeks.')\n",
    "print(f'  Annual net revenue gain: ${annual_net:,.0f} on Route 36 alone.')"
