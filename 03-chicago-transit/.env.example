# ─── Chicago Data Portal ─────────────────────────────────────────────────────
# Register free at: https://data.cityofchicago.org/
CHICAGO_DATA_PORTAL_APP_TOKEN=your_app_token_here

# ─── AWS ─────────────────────────────────────────────────────────────────────
# Free tier: 12 months. IAM user needs S3 + Lambda permissions only.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=hari-cta-raw-archive

# ─── GCP ─────────────────────────────────────────────────────────────────────
# Service account JSON path — do NOT commit the actual file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service_account.json
GCP_PROJECT_ID=your-gcp-project-id
PUBSUB_TOPIC_ID=cta-transit-events
PUBSUB_SUBSCRIPTION_ID=cta-transit-events-sub
BIGQUERY_DATASET=chicago_transit
BIGQUERY_TABLE=transit_events

# ─── Open-Meteo ──────────────────────────────────────────────────────────────
# Free forever, no key required — set Chicago coordinates here
WEATHER_LATITUDE=41.8781
WEATHER_LONGITUDE=-87.6298
WEATHER_TIMEZONE=America/Chicago

# ─── Prefect ─────────────────────────────────────────────────────────────────
# Free tier at https://app.prefect.cloud
PREFECT_API_URL=https://api.prefect.cloud/api/accounts/<account_id>/workspaces/<workspace_id>
PREFECT_API_KEY=your_prefect_api_key

# ─── dbt ─────────────────────────────────────────────────────────────────────
# Copy dbt/profiles.yml.example → dbt/profiles.yml and fill in your GCP project
DBT_PROFILE=chicago_transit
DBT_TARGET=dev
