 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 04 — Anomaly Detection: Service Disruption Flagging\n",
    "\n",
    "**Project:** Chicago Transit & Logistics Intelligence Platform  \n",
    "**Author:** Hari Etta  \n",
    "**Purpose:** Identify days where actual ridership deviates significantly from forecast — flagging service disruptions, severe weather events, and special event surges.\n",
    "\n",
    "## What this notebook covers\n",
    "1. Load forecast vs actual comparison data\n",
    "2. Rolling Z-score methodology — why rolling over global threshold\n",
    "3. IQR dual-method — reducing false positives\n",
    "4. Detected anomalies — table and timeline visualisation\n",
    "5. Anomaly root cause analysis — weather cross-reference\n",
    "6. False positive rate estimation\n",
    "7. Anomaly export for Tableau dashboard"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, sys, warnings, pickle\n",
    "warnings.filterwarnings('ignore')\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.dates as mdates\n",
    "import seaborn as sns\n",
    "from pathlib import Path\n",
    "\n",
    "from forecasting.anomaly_detection import AnomalyDetector\n",
    "from forecasting.train_prophet import ProphetForecaster\n",
    "from forecasting.evaluate_forecast import ForecastEvaluator\n",
    "\n",
    "plt.style.use('seaborn-v0_8-whitegrid')\n",
    "plt.rcParams['figure.figsize'] = (16, 6)\n",
    "\n",
    "MODEL_DIR = Path('../models')\n",
    "print('Libraries loaded.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Data and Forecasts"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "try:\n",
    "    df = pd.read_parquet('../data/processed/features.parquet')\n",
    "except FileNotFoundError:\n",
    "    df = pd.read_csv('../data/sample/cta_ridership_sample.csv', parse_dates=['service_date'])\n",
    "    df['rides'] = pd.to_numeric(df['rides'], errors='coerce')\n",
    "\n",
    "df['service_date'] = pd.to_datetime(df['service_date'])\n",
    "TARGET_ROUTES = ['22', '77', '36', '49']\n",
    "print(f'Loaded {len(df):,} rows.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Rolling Z-score Methodology"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Demonstrate why rolling > global threshold\n",
    "r22 = df[df['route'] == '22'].sort_values('service_date').copy()\n",
    "\n",
    "fig, axes = plt.subplots(2, 1, figsize=(16, 10))\n",
    "\n",
    "# Global std threshold\n",
    "global_mean = r22['rides'].mean()\n",
    "global_std  = r22['rides'].std()\n",
    "r22['global_z'] = (r22['rides'] - global_mean) / global_std\n",
    "global_anomalies = r22[r22['global_z'].abs() > 2]\n",
    "\n",
    "axes[0].plot(r22['service_date'], r22['rides'], alpha=0.5, color='steelblue', linewidth=0.8)\n",
    "axes[0].scatter(global_anomalies['service_date'], global_anomalies['rides'],\n",
    "                color='red', s=25, zorder=5, label=f'Flagged ({len(global_anomalies)})')\n",
    "axes[0].set_title('Global Z-score (|Z|>2): Flags seasonal lows as anomalies — incorrect', fontweight='bold')\n",
    "axes[0].set_ylabel('Daily Rides')\n",
    "axes[0].legend()\n",
    "\n",
    "# Rolling Z-score\n",
    "rolling_mean = r22['rides'].rolling(14, min_periods=7).mean()\n",
    "rolling_std  = r22['rides'].rolling(14, min_periods=7).std()\n",
    "r22['rolling_z'] = (r22['rides'] - rolling_mean) / rolling_std.replace(0, np.nan)\n",
    "rolling_anomalies = r22[r22['rolling_z'].abs() > 2]\n",
    "\n",
    "axes[1].plot(r22['service_date'], r22['rides'], alpha=0.5, color='steelblue', linewidth=0.8)\n",
    "axes[1].scatter(rolling_anomalies['service_date'], rolling_anomalies['rides'],\n",
    "                color='red', s=25, zorder=5, label=f'Flagged ({len(rolling_anomalies)})')\n",
    "axes[1].set_title('Rolling Z-score (14-day window, |Z|>2): Adapts to seasonal patterns — correct', fontweight='bold')\n",
    "axes[1].set_ylabel('Daily Rides')\n",
    "axes[1].set_xlabel('Date')\n",
    "axes[1].legend()\n",
    "\n",
    "for ax in axes:\n",
    "    ax.xaxis.set_major_formatter(mdates.DateFormatter('%b %Y'))\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../docs/anomaly_methodology.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(f'Global Z-score flags: {len(global_anomalies)} (many are seasonal, not disruptions)')\n",
    "print(f'Rolling Z-score flags: {len(rolling_anomalies)} (adapts to local patterns)')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Run Anomaly Detection with Prophet Forecast"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "detector = AnomalyDetector(z_threshold=2.0, window=14, require_both_methods=True)\n",
    "all_anomalies = []\n",
    "\n",
    "for route in TARGET_ROUTES:\n",
    "    model_path = MODEL_DIR / f'prophet_{route}_morning_peak.pkl'\n",
    "    if not model_path.exists():\n",
    "        print(f'Route {route}: No saved model — using series-based detection.')\n",
    "        route_df = df[df['route'] == route].copy()\n",
    "        anomalies = detector.detect_from_series(route_df, route=route)\n",
    "    else:\n",
    "        forecaster = ProphetForecaster.load(model_path)\n",
    "        route_df = df[df['route'] == route].copy()\n",
    "        evaluator = ForecastEvaluator(forecaster)\n",
    "        comparison = evaluator.forecast_vs_actual_df(route_df, horizon_days=28)\n",
    "\n",
    "        # Build forecast df in the format detector expects\n",
    "        forecast_input = comparison[['ds','yhat','route']].copy()\n",
    "        anomalies = detector.detect(route_df, forecast_input)\n",
    "\n",
    "    if not anomalies.empty:\n",
    "        anomalies['route'] = route\n",
    "        all_anomalies.append(anomalies)\n",
    "        print(f'Route {route}: {len(anomalies)} anomalies detected')\n",
    "    else:\n",
    "        print(f'Route {route}: No anomalies detected')\n",
    "\n",
    "if all_anomalies:\n",
    "    anomalies_df = pd.concat(all_anomalies, ignore_index=True)\n",
    "    print(f'\\nTotal anomalies: {len(anomalies_df)}')\n",
    "else:\n",
    "    anomalies_df = pd.DataFrame()\n",
    "    print('\\nNo anomalies detected across all routes.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Anomaly Summary Table"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if not anomalies_df.empty:\n",
    "    print('=== Detected Anomalies ===')\n",
    "    display_cols = ['route','service_date','actual_rides','forecast_rides',\n",
    "                    'residual','z_score','anomaly_type','severity']\n",
    "    display_cols = [c for c in display_cols if c in anomalies_df.columns]\n",
    "    print(anomalies_df[display_cols].sort_values('service_date').to_string(index=False))\n",
    "\n",
    "    print('\\n--- Summary by type ---')\n",
    "    print(anomalies_df['anomaly_type'].value_counts())\n",
    "    print('\\n--- Summary by severity ---')\n",
    "    print(anomalies_df['severity'].value_counts())\n",
    "else:\n",
    "    print('No anomalies to display.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Anomaly Timeline Visualisation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "PLOT_ROUTE = '22'\n",
    "route_df = df[df['route'] == PLOT_ROUTE].sort_values('service_date').copy()\n",
    "\n",
    "model_path = MODEL_DIR / f'prophet_{PLOT_ROUTE}_morning_peak.pkl'\n",
    "if model_path.exists():\n",
    "    forecaster = ProphetForecaster.load(model_path)\n",
    "    evaluator = ForecastEvaluator(forecaster)\n",
    "    comp = evaluator.forecast_vs_actual_df(route_df, horizon_days=28)\n",
    "    comp['ds'] = pd.to_datetime(comp['ds'])\n",
    "    route_anomalies = anomalies_df[anomalies_df['route'] == PLOT_ROUTE] if not anomalies_df.empty else pd.DataFrame()\n",
    "\n",
    "    fig, axes = plt.subplots(2, 1, figsize=(16, 10))\n",
    "\n",
    "    # Forecast vs actual\n",
    "    recent = comp[comp['ds'] >= comp['ds'].max() - pd.Timedelta(days=180)]\n",
    "    axes[0].fill_between(recent['ds'], recent['yhat_lower'], recent['yhat_upper'],\n",
    "                         alpha=0.2, color='steelblue')\n",
    "    axes[0].plot(recent['ds'], recent['yhat'], color='steelblue', linewidth=1.5, label='Forecast')\n",
    "    actuals_mask = recent['is_actual']\n",
    "    axes[0].scatter(recent.loc[actuals_mask, 'ds'], recent.loc[actuals_mask, 'actual_rides'],\n",
    "                    s=10, color='navy', alpha=0.6, label='Actual')\n",
    "\n",
    "    if not route_anomalies.empty:\n",
    "        route_anomalies['service_date'] = pd.to_datetime(route_anomalies['service_date'])\n",
    "        critical = route_anomalies[route_anomalies['severity'] == 'critical']\n",
    "        moderate = route_anomalies[route_anomalies['severity'].isin(['moderate','minor'])]\n",
    "        if not critical.empty:\n",
    "            axes[0].scatter(critical['service_date'], critical['actual_rides'],\n",
    "                            s=100, color='red', zorder=6, marker='^', label='Critical anomaly')\n",
    "        if not moderate.empty:\n",
    "            axes[0].scatter(moderate['service_date'], moderate['actual_rides'],\n",
    "                            s=60, color='orange', zorder=6, marker='^', label='Moderate anomaly')\n",
    "\n",
    "    axes[0].set_title(f'Route {PLOT_ROUTE} — Forecast vs Actual with Anomaly Flags', fontweight='bold')\n",
    "    axes[0].set_ylabel('Daily Rides')\n",
    "    axes[0].legend()\n",
    "    axes[0].xaxis.set_major_formatter(mdates.DateFormatter('%b %Y'))\n",
    "\n",
    "    # Residuals\n",
    "    residuals = recent[recent['is_actual']].copy()\n",
    "    residuals['residual'] = residuals['actual_rides'] - residuals['yhat']\n",
    "    axes[1].bar(residuals['ds'], residuals['residual'],\n",
    "                color=['red' if r < -1000 else 'coral' if r < 0 else 'steelblue'\n",
    "                       for r in residuals['residual']],\n",
    "                width=1, edgecolor='none')\n",
    "    axes[1].axhline(0, color='black', linewidth=1)\n",
    "    axes[1].set_title('Residuals (Actual − Forecast)', fontweight='bold')\n",
    "    axes[1].set_ylabel('Residual (rides)')\n",
    "    axes[1].xaxis.set_major_formatter(mdates.DateFormatter('%b %Y'))\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.savefig('../docs/anomaly_timeline.png', dpi=150, bbox_inches='tight')\n",
    "    plt.show()\n",
    "else:\n",
    "    print(f'No saved model for Route {PLOT_ROUTE}. Train models in notebook 03 first.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Export Anomalies for Tableau"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if not anomalies_df.empty:\n",
    "    # Ensure service_date is string for CSV export\n",
    "    export = anomalies_df.copy()\n",
    "    for col in ['service_date','flagged_at']:\n",
    "        if col in export.columns:\n",
    "            export[col] = export[col].astype(str)\n",
    "\n",
    "    export.to_csv('../data/processed/anomalies.csv', index=False)\n",
    "    print(f'Exported {len(export)} anomaly records to data/processed/anomalies.csv')\n",
    "    print('Connect this CSV to Tableau for the demand forecast anomaly markers tab.')\n",
    "else:\n",
    "    print('No anomalies to export.')"
   ]
  }
 ],
